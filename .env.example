# ---- G1 Basic WebRTC controller ----
# The robot is reached over Wi-Fi via the SAME WebRTC channel the Unitree app uses
# (no SDK / DDS / jailbreak). Put the robot in STA mode (so it joins your Wi-Fi) and find
# its IP in the Unitree app, OR join the robot's own AP and use localap.

DEVICE_TYPE=G1                 # G1 | Go2
CONN_MODE=localsta            # localsta (robot on your LAN, by IP) | localap (robot hotspot) | remote (TURN)
ROBOT_IP=192.168.1.50         # localsta: the robot's IP (from the Unitree app)
ROBOT_SERIAL=                 # remote / sta-by-serial (Go2). On the robot label / app.

# Unitree account — needed ONLY for remote (TURN) mode and to fetch the AES key.
UNITREE_EMAIL=
UNITREE_PASSWORD=

# Per-device handshake key — REQUIRED on G1 firmware >= 1.5.1 (Go2 >= 1.1.15).
# Fetch once:  unitree-fetch-aes-key --email you@x.com --sn <SERIAL> --device-type G1
UNITREE_AES_128_KEY=

# ---- Safety (this is a HUMANOID) ----
ALLOW_MOVEMENT=false          # motion commands are refused unless this is true
MAX_VX=0.3                    # m/s
MAX_VY=0.2                    # m/s
MAX_VYAW=0.5                  # rad/s
